# Copy to `.env.local` (Next.js) and/or `.env`. drizzle-kit loads `.env` then `.env.local` — see drizzle.config.ts
DATABASE_URL=postgres://postgres:mypassword@localhost:5432/postgres
NEXTAUTH_SECRET=replace_with_a_long_random_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Mailpit (local dev): `docker compose up -d mailpit` then open http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
# Optional: set only if your SMTP server requires auth (Mailpit does not by default)
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false
EMAIL_FROM=Influencers Billing <billing@localhost>
ADMIN_BOOTSTRAP_KEY=replace_with_admin_bootstrap_secret

